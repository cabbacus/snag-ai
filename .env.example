# OpenAI API key with GPT-4o Vision access
OPENAI_API_KEY=

# Main frontend origin for CORS (localhost + *.ngrok-free.app are always allowed)
FRONTEND_URL=http://localhost:5173

# Optional extra CORS origins, comma-separated (e.g. a frontend ngrok URL)
EXTRA_CORS_ORIGINS=

# Port for uvicorn (informational — set in start command)
PORT=3001
